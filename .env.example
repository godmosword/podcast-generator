OPENAI_API_KEY=sk-...
ELEVENLABS_API_KEY=...
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-3-flash-preview

APP_ENV=development

# Optional: path to background music file
BGM_PATH=

# Default TTS provider: edge | openai | elevenlabs
TTS_PROVIDER=edge

# Output directory
OUTPUT_DIR=output

# How long API job snapshots/output files are retained in memory/on disk
JOB_TTL_SECONDS=21600

# Comma-separated allowed frontend origins for the API CORS policy
CORS_ORIGINS=http://localhost:3000

# Trust X-Forwarded-For only from these proxy/CDN CIDRs
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_CIDRS=

# Per-IP API rate limits
RATE_LIMIT_GENERATE_PER_MINUTE=5
RATE_LIMIT_PREVIEW_PER_MINUTE=20
RATE_LIMIT_AI_PER_MINUTE=10

# Frontend API base URL when running Vite locally
VITE_API_BASE_URL=http://localhost:8000

# Storage backend: local | s3  (default: local)
STORAGE_BACKEND=local

# S3 storage — required when STORAGE_BACKEND=s3
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Max script length in characters (default: 50000)
MAX_SCRIPT_LENGTH=50000
